{
  "$note": "Real-page Lighthouse gate for the GitHub PR check (.github/workflows/ci.yml `lighthouse` job). Runs against the production build (staticDistDir) on mobile emulation, matching the Netlify dashboard. Thresholds are per-route floors calibrated 2026-06-30 against the live build — see docs/lighthouse-baseline-2026-06-30.md. This is intentionally separate from the sync-managed lighthouserc.json (which is the fleet a11y-fixtures config).",
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "url": [
        "http://localhost/index.html",
        "http://localhost/surgical-grafts/allografts.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*/index\\.html$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.55 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.7 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        },
        {
          "matchingUrlPattern": ".*/surgical-grafts/allografts\\.html$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.85 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.7 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
