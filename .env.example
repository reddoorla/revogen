# Fleet forms: set BOTH in this site's Netlify env. Do NOT commit the real FORMS_INGEST_URL value (Netlify secrets-scan).
# This site's slug: revogen
FORMS_INGEST_URL=https://reddoor-maintenance.netlify.app/api/forms/<slug>
FORMS_INGEST_TOKEN=replace-with-the-shared-forms-ingest-token

# Distributor Resource Hub gate. Set in this site's Netlify env. The portal
# fails closed (no documents served) until this is set. Rotate the value that
# was previously hardcoded in the client.
DISTRIBUTOR_PASSWORD=replace-with-the-distributor-portal-password
