{
  "name": "sveltekit-prismic-starter-t-lemos",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently \"pnpm:vite:dev\" \"pnpm:slicemachine\" --prefix-colors blue,magenta",
    "vite:dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
    "format": "prettier --write . --plugin prettier-plugin-svelte .",
    "slicemachine": "start-slicemachine"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@reddoorla/maintenance": "^0.58.0",
    "@slicemachine/adapter-sveltekit": "^0.3.95",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "slice-machine-ui": "^2.21.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-svelte-plugin": "^0.3.51",
    "vite": "^7.3.2"
  },
  "type": "module",
  "dependencies": {
    "@lucide/svelte": "^1.20.0",
    "@prismicio/client": "^7.21.8",
    "@prismicio/svelte": "^2.2.1",
    "@rive-app/canvas": "^2.37.5",
    "@tailwindcss/vite": "^4.2.4",
    "@zerodevx/svelte-img": "^2.1.2",
    "svelte-gestures": "^5.2.2",
    "svelte-select": "^5.8.3"
  }
}
